# Пример 1. Простая модель процессов и ролей.
# Каждый объект относится к некоторому МегаТипу через предикат :МегаТип.
@prefix : <http://example.org/bpm#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

:Процесс_А :МегаТип :Процесс ;
    rdfs:label "Согласование договора" ;
    :владелец :Иванов ;
    :входит_в :Процесс_Б .

:Процесс_Б :МегаТип :Процесс ;
    rdfs:label "Управление договорами" ;
    :владелец :Петров .

:Иванов :МегаТип :Роль ;
    rdfs:label "Менеджер по договорам" .

:Петров :МегаТип :Роль ;
    rdfs:label "Руководитель отдела" .
