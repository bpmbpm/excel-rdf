# Пример 3. Объекты с МегаТипом и обычные триплеты без МегаТипа.
# Триплеты субъектов без :МегаТип попадают на лист «Прочие триплеты».
@prefix : <http://example.org/cat#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

# Объекты с МегаТипом
:Товар_1 :МегаТип :Товар ;
    rdfs:label "Ноутбук" ;
    :цена "75000" ;
    :категория :Электроника .

:Товар_2 :МегаТип :Товар ;
    rdfs:label "Мышь" ;
    :цена "1200" ;
    :категория :Электроника .

# Описание класса без МегаТипа — попадёт на лист «Прочие триплеты»
:Товар a owl:Class ;
    rdfs:label "Товар" .
