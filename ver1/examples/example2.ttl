# Пример 2. Несколько объектов на один предикат (через запятую)
# и несколько предикатов на субъект (через точку с запятой).
@prefix : <http://example.org/org#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

:Отдел_Продаж :МегаТип :Подразделение ;
    rdfs:label "Отдел продаж" ;
    :включает :Сидоров , :Кузнецов , :Смирнов .

:Отдел_Закупок :МегаТип :Подразделение ;
    rdfs:label "Отдел закупок" ;
    :включает :Морозов .

:Сидоров :МегаТип :Сотрудник ;
    rdfs:label "Сидоров А.А." ;
    :должность "Менеджер" .

:Кузнецов :МегаТип :Сотрудник ;
    rdfs:label "Кузнецов Б.Б." ;
    :должность "Менеджер" .

:Смирнов :МегаТип :Сотрудник ;
    rdfs:label "Смирнов В.В." ;
    :должность "Старший менеджер" .

:Морозов :МегаТип :Сотрудник ;
    rdfs:label "Морозов Г.Г." ;
    :должность "Закупщик" .
