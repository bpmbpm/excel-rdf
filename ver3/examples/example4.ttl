# Пример 4. Детальный пример с большим числом предикатов (редакция ver2).
#
# Демонстрирует:
#   • несколько МегаТипов (Процесс, Роль, Документ, Система);
#   • у субъектов одного МегаТипа много предикатов (полей);
#   • разные наборы предикатов у разных МегаТипов — их удобно сравнивать
#     в одном месте на листе «main» (см. столбец «Предикаты»);
#   • несколько объектов на один предикат (через запятую).
@prefix : <http://example.org/bpm#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

# --- МегаТип «Процесс»: много предикатов ---
:Прием_заявки :МегаТип :Процесс ;
    rdfs:label "Приём заявки" ;
    dcterms:description "Регистрация входящей заявки клиента" ;
    :владелец :Менеджер ;
    :входныеДанные :Заявка ;
    :выходныеДанные :ЗарегистрированнаяЗаявка ;
    :использует :CRM ;
    :следующий :Проверка_заявки ;
    :длительность "PT2H" ;
    :приоритет "Высокий" .

:Проверка_заявки :МегаТип :Процесс ;
    rdfs:label "Проверка заявки" ;
    dcterms:description "Проверка корректности и полноты заявки" ;
    :владелец :Аналитик ;
    :входныеДанные :ЗарегистрированнаяЗаявка ;
    :выходныеДанные :ПровереннаяЗаявка ;
    :использует :CRM , :Хранилище ;
    :следующий :Согласование ;
    :длительность "PT4H" ;
    :приоритет "Средний" .

:Согласование :МегаТип :Процесс ;
    rdfs:label "Согласование" ;
    dcterms:description "Согласование заявки с руководителем" ;
    :владелец :Руководитель ;
    :входныеДанные :ПровереннаяЗаявка ;
    :выходныеДанные :Решение ;
    :использует :Почта ;
    :длительность "P1D" ;
    :приоритет "Средний" .

# --- МегаТип «Роль»: иной набор предикатов ---
:Менеджер :МегаТип :Роль ;
    rdfs:label "Менеджер по работе с клиентами" ;
    :подразделение :Отдел_продаж ;
    :уровеньДоступа "Базовый" ;
    :ответственность "Регистрация заявок" .

:Аналитик :МегаТип :Роль ;
    rdfs:label "Аналитик" ;
    :подразделение :Отдел_аналитики ;
    :уровеньДоступа "Расширенный" ;
    :ответственность "Проверка данных" .

:Руководитель :МегаТип :Роль ;
    rdfs:label "Руководитель отдела" ;
    :подразделение :Отдел_продаж ;
    :уровеньДоступа "Полный" ;
    :ответственность "Принятие решений" , "Контроль качества" .

# --- МегаТип «Документ» ---
:Заявка :МегаТип :Документ ;
    rdfs:label "Заявка клиента" ;
    :формат "PDF" ;
    :статус "Черновик" .

:ПровереннаяЗаявка :МегаТип :Документ ;
    rdfs:label "Проверенная заявка" ;
    :формат "PDF" ;
    :статус "Проверен" .

:Решение :МегаТип :Документ ;
    rdfs:label "Решение по заявке" ;
    :формат "DOCX" ;
    :статус "Утверждён" .

# --- МегаТип «Система» ---
:CRM :МегаТип :Система ;
    rdfs:label "CRM-система" ;
    :производитель "ООО Вектор" ;
    :версия "3.2" .

:Хранилище :МегаТип :Система ;
    rdfs:label "Файловое хранилище" ;
    :производитель "ООО Архив" ;
    :версия "1.0" .

:Почта :МегаТип :Система ;
    rdfs:label "Корпоративная почта" ;
    :производитель "ООО Связь" ;
    :версия "2.5" .
